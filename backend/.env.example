APP_NAME="AI Sales Teammate API"
APP_VERSION="0.1.0"
ENVIRONMENT=local

FRONTEND_ORIGIN=http://localhost:3000
CORS_EXTRA_ORIGINS=[]

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_sales_teammate
REDIS_URL=redis://localhost:6379/0
APPROVAL_WORKER_FAILURE_MODE=none
APPROVAL_JOB_STALE_AFTER_SECONDS=300

JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
AUTH_COOKIE_NAME=ai_sales_session
AUTH_COOKIE_MAX_AGE_SECONDS=86400
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
SIGNUP_RATE_LIMIT_ATTEMPTS=5
SIGNUP_RATE_LIMIT_WINDOW_SECONDS=60
SIGNUP_DEMO_DATA_ENABLED=true
REVIEWER_INVITE_CODE=demo-reviewer-code

LLM_PROVIDER=mock
LLM_RUNTIME_SWITCHING_ENABLED=false
LLM_MOCK_ENABLED=true
LLM_ALLOW_MOCK_FALLBACK=true
MOCK_LLM_FAILURE_MODE=none

# Set these only when enabling Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_VALIDATE_MODEL_ON_STARTUP=true
ANTHROPIC_STRUCTURED_OUTPUT_MODE=tool_use

LLM_STRUCTURED_OUTPUTS_ENABLED=true
LLM_DECISION_TRACE_ENABLED=true
LLM_EXTENDED_THINKING_ENABLED=false
LLM_THINKING_MODE=off
LLM_THINKING_BUDGET_TOKENS=1024
LLM_EXPOSE_PROVIDER_THINKING_SUMMARY=false
